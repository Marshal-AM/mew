{
  "name": "wallet-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "prebuild": "expo prebuild",
    "android": "expo run:android",
    "android:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/run-android-dev.ps1",
    "android:install-debug": "powershell -ExecutionPolicy Bypass -File ./scripts/install-debug.ps1",
    "ios": "expo run:ios",
    "typecheck": "npx --yes --package typescript@~5.3.3 tsc --noEmit",
    "test:protocol": "node ./scripts/test-chunk-protocol.mjs",
    "test:signing": "node ./scripts/test-signing.mjs",
    "test:auth-gate": "node ./scripts/test-auth-gate.mjs",
    "release:preflight": "powershell -ExecutionPolicy Bypass -File ./scripts/preflight-release.ps1",
    "build:apk": "powershell -ExecutionPolicy Bypass -File ./scripts/build-release.ps1",
    "build:apk:arm64": "powershell -ExecutionPolicy Bypass -Command \"$env:REACT_NATIVE_ARCHITECTURES='arm64-v8a'; ./scripts/build-release.ps1\"",
    "check:path-budget": "powershell -ExecutionPolicy Bypass -File ./scripts/check-path-budget.ps1",
    "build:apk:relocated": "powershell -ExecutionPolicy Bypass -File ./scripts/build-relocated-release.ps1",
    "logs:capture": "powershell -ExecutionPolicy Bypass -File ./scripts/capture-logs.ps1"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.49.1",
    "ethers": "^6.13.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-camera": "~16.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-linking": "~7.0.0",
    "expo-local-authentication": "~14.0.1",
    "expo-network": "~7.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-ble-plx": "^3.4.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "babel-plugin-module-resolver": "^5.0.0",
    "typescript": "^5.3.3"
  }
}
